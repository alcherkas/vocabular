[
  {
    "term": "abdication",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The formal act of renouncing or surrendering a position of power, authority, or responsibility, especially a throne or high office.",
        "example": "The king's abdication shocked the nation, leaving the question of succession unresolved for months.",
        "register": "formal",
        "tags": [
          "politics",
          "governance",
          "history"
        ]
      },
      {
        "definition": "The abandonment or shirking of a duty, responsibility, or moral obligation.",
        "example": "Critics accused the board of a complete abdication of their fiduciary duty to shareholders.",
        "register": "formal",
        "tags": [
          "ethics",
          "law",
          "governance"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "aberration",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "A departure from what is normal, expected, or typical; a deviation from the standard or usual course.",
        "example": "The scientist noted that this anomalous reading was an aberration rather than evidence of a new phenomenon.",
        "register": "formal",
        "tags": [
          "science",
          "statistics",
          "logic"
        ]
      },
      {
        "definition": "A distortion in an optical image resulting from defects in a lens or mirror, causing blurring or colour fringing.",
        "example": "The telescope's chromatic aberration was corrected by introducing a secondary lens element.",
        "register": "technical",
        "tags": [
          "optics",
          "physics"
        ]
      },
      {
        "definition": "A temporary departure from a normal or correct state of mind; a momentary lapse in behaviour or judgement.",
        "example": "He later described the outburst as a brief aberration brought on by months of accumulated stress.",
        "register": "formal",
        "tags": [
          "psychology",
          "behaviour"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "abiogenesis",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The hypothetical natural process by which life arises from non-living matter, such as simple organic compounds, without any biological parent.",
        "example": "The Miller–Urey experiment was a landmark attempt to demonstrate abiogenesis under conditions resembling the early Earth.",
        "register": "technical",
        "tags": [
          "biology",
          "chemistry",
          "origins-of-life"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "abscission",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The natural and controlled shedding of a part of an organism, such as a leaf, fruit, flower, or tail, by the formation of a specialised layer of cells at its base.",
        "example": "Autumnal abscission is triggered by declining day length and the conversion of auxin signals at the separation zone.",
        "register": "technical",
        "tags": [
          "botany",
          "biology",
          "physiology"
        ]
      },
      {
        "definition": "The surgical cutting away of a diseased or superfluous part; excision.",
        "example": "The surgeon performed a careful abscission of the necrotic tissue to prevent further spread of infection.",
        "register": "technical",
        "tags": [
          "medicine",
          "surgery"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
