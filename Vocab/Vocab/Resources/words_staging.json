    "term": "annulment",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "A legal or formal declaration that a marriage, contract, or other legal act is null and void, as if it had never existed.",
        "example": "The couple sought an annulment on the grounds that valid consent had not been given at the time of the wedding.",
        "register": "formal",
        "tags": [
          "law",
          "marriage",
          "contracts"
        ]
      },
      {
        "definition": "The cancellation or invalidation of an official decision, agreement, or action.",
        "example": "The court ordered the annulment of the election results following evidence of widespread electoral fraud.",
        "register": "formal",
        "tags": [
          "law",
          "governance",
