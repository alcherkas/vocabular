[
  {
    "term": "expatriate",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "A person who lives outside their native country, especially for work or lifestyle reasons.",
        "example": "The company employed a large number of expatriates in its Singapore office, many of whom had been relocated from European headquarters.",
        "register": "neutral",
        "tags": [
          "migration",
          "employment",
          "globalisation"
        ]
      },
      {
        "definition": "To banish someone from their native country; to renounce allegiance to one's own country.",
        "example": "In the 19th century, political dissidents were often expatriated by authoritarian regimes seeking to silence opposition abroad.",
        "register": "formal",
        "tags": [
          "exile",
          "history",
          "law"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "expediency",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The quality of being convenient and practical despite possibly being improper or immoral; action guided by self-interest rather than principle.",
        "example": "The decision to compromise on environmental protections was widely condemned as a triumph of political expediency over long-term responsibility.",
        "register": "formal",
        "tags": [
          "ethics",
          "politics",
          "pragmatism"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "extenuation",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The action of making an offence, fault, or mistake seem less serious by providing partial justification or mitigating circumstances.",
        "example": "The defence counsel offered extenuation by pointing to the defendant's difficult upbringing and lack of prior criminal history.",
        "register": "formal",
        "tags": [
          "law",
          "ethics",
          "rhetoric"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "fabrication",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The action of manufacturing or constructing something, especially an industrial product.",
        "example": "The steel fabrication process involved cutting, bending, and assembling components to precise engineering tolerances.",
        "register": "technical",
        "tags": [
          "manufacturing",
          "engineering",
          "industry"
        ]
      },
      {
        "definition": "The action of inventing or constructing something false; a lie or invented story.",
