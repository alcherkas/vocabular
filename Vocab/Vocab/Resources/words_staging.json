    "term": "fatalism",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The belief that all events are predetermined and inevitable, and that human beings are powerless to alter the course of fate.",
        "example": "His passive acceptance of every setback struck his colleagues as a form of fatalism that prevented him from seeking practical solutions.",
        "register": "formal",
        "tags": [
          "philosophy",
          "psychology",
          "religion"
        ]
      }
    ],
    "synonyms": [],
