  },
  {
    "term": "overbearing",
    "language": "en",
    "partOfSpeech": "adjective",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Behaving in an excessively controlling, domineering, or arrogant manner toward others.",
        "example": "His overbearing management style stifled creativity and led to unusually high staff turnover.",
        "register": "general",
        "tags": [
          "personality",
          "behavior",
          "negative"
        ]
      },
      {
        "definition": "Overwhelming in force, intensity, or effect so as to suppress all opposition.",
        "example": "The overbearing heat of the desert made any outdoor exertion hazardous during the midday hours.",
        "register": "literary",
        "tags": [
          "intensity",
          "force",
          "overwhelming"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
