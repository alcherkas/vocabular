    "term": "amalgamation",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The action or process of combining or uniting two or more things into a single entity; a merger.",
        "example": "The amalgamation of the two regional banks created the largest financial institution in the province.",
        "register": "formal",
        "tags": [
          "business",
          "law",
          "organisation"
        ]
      },
      {
        "definition": "The process of alloying mercury with another metal, used in mining to extract gold or silver from ore.",
