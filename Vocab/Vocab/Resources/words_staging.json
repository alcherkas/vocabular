  {
    "term": "fecundity",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "The ability to produce an abundance of offspring or new growth; fertility.",
        "example": "The extraordinary fecundity of the species allowed it to repopulate the restored habitat within just two breeding seasons.",
        "register": "technical",
        "tags": [
          "biology",
          "ecology",
          "reproduction"
        ]
      },
      {
        "definition": "The quality of producing new and creative ideas in great abundance; intellectual or creative productivity.",
        "example": "The fecundity of her imagination was remarkable; she generated dozens of viable project concepts in a single workshop session.",
        "register": "formal",
        "tags": [
          "creativity",
          "intellectual",
          "arts"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "finesse",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Refined and delicate skill in handling a situation; elegance, subtlety, and sophistication in execution.",
        "example": "The ambassador's handling of the trade dispute showed considerable finesse, avoiding any public embarrassment for either party.",
        "register": "neutral",
        "tags": [
          "skill",
          "diplomacy",
          "elegance"
        ]
      },
      {
        "definition": "In card games such as bridge, an attempt to win a trick with a lower card while holding a higher one, hoping the intervening card is held by a specific opponent.",
        "example": "He attempted a finesse with the queen, gambling that the king was held by the opponent on his right.",
        "register": "technical",
        "tags": [
          "cards",
          "bridge",
          "games"
        ]
      }
    ],
