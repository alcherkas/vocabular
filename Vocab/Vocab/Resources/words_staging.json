    "term": "fulmination",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "An expression of vehement protest, condemnation, or verbal anger; a thunderous denunciation.",
        "example": "The senator's fulmination against the proposed legislation electrified the chamber but ultimately failed to sway the vote.",
        "register": "formal",
        "tags": [
          "rhetoric",
          "politics",
          "emotion"
        ]
      },
      {
        "definition": "In chemistry, a violent explosive reaction or the production of a fulminate compound.",
        "example": "The fulmination reaction produced an explosive force far exceeding what the laboratory equipment was designed to contain.",
        "register": "technical",
        "tags": [
          "chemistry",
          "explosives"
        ]
      }
    ],
