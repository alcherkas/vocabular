    "term": "penultimate",
    "language": "en",
    "partOfSpeech": "adjective",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Occurring immediately before the last item in a sequence, series, or ranking.",
        "example": "In the penultimate chapter, the author finally reveals the identity of the elusive antagonist.",
        "register": "formal",
        "tags": [
          "sequence",
          "position",
          "order"
        ]
      },
      {
        "definition": "Relating to or denoting the second-to-last syllable of a word.",
        "example": "In classical Latin, stress regularly falls on the penultimate syllable when it is long.",
        "register": "technical",
        "tags": [
          "linguistics",
          "phonology",
          "syllable"
        ]
      }
    ],
    "synonyms": [],
