  {
    "term": "philistine",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "A person who is hostile or indifferent to culture and the arts, or who has no appreciation of fine literature, art, or music.",
        "example": "He dismissed the novel as pretentious, prompting colleagues to accuse him of being a thoroughgoing philistine.",
        "register": "formal",
        "tags": [
          "culture",
          "aesthetics",
          "criticism"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
