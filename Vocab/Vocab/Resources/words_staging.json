  {
    "term": "pontificate",
    "language": "en",
    "partOfSpeech": "verb",
    "status": "enriched",
    "meanings": [
      {
        "definition": "To express one's opinions in a pompous and dogmatic way, as if one has superior authority or knowledge.",
        "example": "He tended to pontificate on matters of public policy even when he had little direct expertise.",
        "register": "formal",
        "tags": [
          "rhetoric",
          "behaviour",
          "arrogance"
        ]
      },
      {
        "definition": "To officiate as a pontiff, especially to celebrate mass as a bishop with full ceremonial rites.",
