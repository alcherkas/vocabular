    "term": "peremptory",
    "language": "en",
    "partOfSpeech": "adjective",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Insisting on immediate obedience or compliance and not open to any discussion or refusal.",
        "example": "She received a peremptory summons to appear before the disciplinary committee without delay.",
        "register": "formal",
        "tags": [
          "authority",
          "command",
          "tone"
        ]
      },
      {
        "definition": "Of a person or their manner: imperious and expecting immediate compliance without argument.",
        "example": "His peremptory dismissal of every objection made further negotiation impossible.",
        "register": "formal",
        "tags": [
          "behavior",
          "domineering",
          "attitude"
        ]
      }
    ],
