    "term": "acuity",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Sharpness or keenness of perception, thought, vision, or hearing.",
        "example": "Her analytical acuity allowed her to identify the flaw in the argument that had escaped everyone else.",
        "register": "formal",
        "tags": [
          "cognition",
          "perception",
          "intelligence"
        ]
      },
      {
        "definition": "Keenness of vision, measured as the ability to resolve fine spatial detail.",
