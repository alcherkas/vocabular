    "term": "fundamentalism",
    "language": "en",
    "partOfSpeech": "noun",
    "status": "enriched",
    "meanings": [
      {
        "definition": "A strict adherence to the literal interpretation of the founding texts or principles of a religion, especially Protestant Christianity.",
        "example": "Religious fundamentalism shaped the political platform of the movement, which sought to encode biblical law into civil legislation.",
        "register": "formal",
        "tags": [
          "religion",
          "politics",
          "society"
        ]
      },
      {
        "definition": "More broadly, strict and uncompromising adherence to any set of doctrines or principles, including in secular contexts.",
        "example": "Market fundamentalism — the belief that free markets will solve all economic problems — dominated policy thinking in the 1980s.",
        "register": "formal",
        "tags": [
          "ideology",
          "economics",
          "politics"
        ]
      }
