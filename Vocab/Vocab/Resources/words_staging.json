[
  {
    "term": "ordain",
    "language": "en",
    "partOfSpeech": "verb",
    "status": "enriched",
    "meanings": [
      {
        "definition": "To officially establish, order, or decree something by law, authority, or divine will.",
        "example": "The constitution ordains that every citizen is entitled to a fair and speedy trial.",
        "register": "formal",
        "tags": [
          "law",
          "governance",
          "authority"
        ]
      },
      {
        "definition": "To officially confer holy orders upon someone, appointing them as a priest, minister, or rabbi.",
        "example": "She was ordained as a minister after completing six years of theological training.",
        "register": "formal",
        "tags": [
          "religion",
          "ceremony",
          "appointment"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "outmanoeuvre",
    "language": "en",
    "partOfSpeech": "verb",
    "status": "enriched",
    "meanings": [
      {
        "definition": "To gain a strategic or competitive advantage over an opponent through superior tactics, skill, or planning.",
        "example": "The nimble startup outmanoeuvred its larger rivals by targeting niche markets they had overlooked.",
        "register": "general",
        "tags": [
          "strategy",
          "competition",
          "tactics"
        ]
      },
      {
        "definition": "To defeat an opponent in military conflict by executing superior tactical movements.",
        "example": "The general outmanoeuvred the enemy by feigning retreat and then encircling them from the rear.",
        "register": "formal",
        "tags": [
          "military",
          "tactics",
          "warfare"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "overriding",
    "language": "en",
    "partOfSpeech": "adjective",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Of greater importance or influence than all other factors; taking precedence over everything else.",
        "example": "The board's overriding concern throughout the crisis was preserving the company's financial stability.",
        "register": "formal",
        "tags": [
          "priority",
          "importance",
          "dominance"
        ]
      },
      {
        "definition": "Exerting a prevailing or dominant influence that supersedes other considerations.",
        "example": "The overriding theme of the summit was the urgent need for multilateral action on climate change.",
        "register": "neutral",
        "tags": [
          "dominance",
          "priority",
          "influence"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "overbearing",
    "language": "en",
    "partOfSpeech": "adjective",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Behaving in an excessively controlling, domineering, or arrogant manner toward others.",
        "example": "His overbearing management style stifled creativity and led to unusually high staff turnover.",
        "register": "general",
        "tags": [
          "personality",
          "behavior",
          "negative"
        ]
      },
      {
        "definition": "Overwhelming in force, intensity, or effect so as to suppress all opposition.",
        "example": "The overbearing heat of the desert made any outdoor exertion hazardous during the midday hours.",
        "register": "literary",
        "tags": [
          "intensity",
          "force",
          "overwhelming"
        ]
      }
    ],
    "synonyms": [],
    "antonymTerms": [],
    "relatedTerms": [],
    "translation": null
  },
  {
    "term": "penultimate",
    "language": "en",
    "partOfSpeech": "adjective",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Occurring immediately before the last item in a sequence, series, or ranking.",
        "example": "In the penultimate chapter, the author finally reveals the identity of the elusive antagonist.",
        "register": "formal",
        "tags": [
          "sequence",
          "position",
          "order"
        ]
      },
      {
        "definition": "Relating to or denoting the second-to-last syllable of a word.",
        "example": "In classical Latin, stress regularly falls on the penultimate syllable when it is long.",
        "register": "technical",
        "tags": [
          "linguistics",
          "phonology",
          "syllable"
        ]
      }
    ],
