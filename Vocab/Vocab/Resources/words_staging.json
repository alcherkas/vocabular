    "term": "aleatoric",
    "language": "en",
    "partOfSpeech": "adjective",
    "status": "enriched",
    "meanings": [
      {
        "definition": "Depending on the throw of a die or on chance; incorporating random or indeterminate elements as a structural principle, especially in music or art.",
        "example": "Cage's aleatoric compositions challenged the notion that music required conscious authorial control over every parameter.",
        "register": "technical",
        "tags": [
          "music",
          "art",
          "philosophy",
          "randomness"
        ]
      }
    ],
    "synonyms": [],
